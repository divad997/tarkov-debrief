{
  "name": "debrief",
  "version": "0.1.0",
  "homepage": "https://debrief.jrkt.dev",
  "private": true,
  "dependencies": {
    "@trystero-p2p/torrent": "^0.25.1",
    "fabric": "^7.3.1",
    "react": "^18.0.1",
    "react-color": "^2.19.3",
    "react-dom": "^18.0.1",
    "trystero": "^0.25.1",
    "wouter": "^3.3.5"
  },
  "scripts": {
    "start": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "optimize:maps": "node scripts/optimize-maps.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "build": "tsc --noEmit && eslint src && vite build",
    "predeploy": "vite build",
    "deploy": "gh-pages -d build"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.0.0",
    "@types/react": "^18.0.0",
    "@types/react-color": "^3.0.4",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gh-pages": "^6.x",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.0",
      "onFail": "download"
    }
  }
}
