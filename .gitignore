# dependencies
# Match node_modules at any depth (root + workspace packages like server/)
node_modules
/.pnp
.pnp.js

# testing
/coverage

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*

.eslintcache

.vscode/
build/

# editor scratch
**/.nvimlog
*.swp

# Windows download metadata (NTFS alternate data streams)
*:Zone.Identifier

# SSH keys — should never be in the repo
sshkey
sshkey.pub
*.pem
id_rsa
id_ed25519

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
